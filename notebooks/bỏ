        "all_null_info = {}\n",
        "\n",
        "for name, df in raw_dfs.items():\n",
        "    n_rows = table_stats[name][\"rows\"]\n",
        "    n_cols = len(df.columns)\n",
        "\n",
        "    null_exprs = [\n",
        "        F.sum(F.when(F.col(c).isNull(), F.lit(1)).otherwise(F.lit(0))).alias(c)\n",
        "        for c in df.columns\n",
        "    ]\n",
        "    null_counts = df.agg(*null_exprs).collect()[0].asDict()\n",
        "\n",
        "    null_data = [\n",
        "        (col, cnt, round(cnt / n_rows * 100, 2))\n",
        "        for col, cnt in null_counts.items()\n",
        "        if cnt > 0\n",
        "    ]\n",
        "    null_data.sort(key=lambda x: x[1], reverse=True)\n",
        "    all_null_info[name] = null_data\n",
        "\n",
        "    total_null_cells = sum(cnt for _, cnt, _ in null_data)\n",
        "    total_cells = n_rows * n_cols\n",
        "    overall_pct = round(total_null_cells / total_cells * 100, 2) if total_cells > 0 else 0\n",
        "\n",
        "    cols_gt50 = sum(1 for _, _, pct in null_data if pct > 50)\n",
        "    cols_gt30 = sum(1 for _, _, pct in null_data if 30 < pct <= 50)\n",
        "    cols_gt0  = sum(1 for _, _, pct in null_data if 0 < pct <= 30)\n",
        "\n",
        "    print(f\"\\n  ┌── {name}\")\n",
        "    print(f\"  │   Columns with nulls: {len(null_data)} / {n_cols}\")\n",
        "    print(f\"  │   Total null cells:   {total_null_cells:,} / {total_cells:,} ({overall_pct}%)\")\n",
        "    print(f\"  │   Severity breakdown: >50%: {cols_gt50} cols | 30-50%: {cols_gt30} cols | <30%: {cols_gt0} cols\")\n",
        "\n",
        "    if null_data:\n",
        "        print(f\"  │\")\n",
