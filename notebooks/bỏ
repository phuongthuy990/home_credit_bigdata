        "\n",
        "# ── Danh sách file ─────────────────────────────────────────────\n",
        "files = {\n",
        "    \"app_train\": \"application_train.csv\",\n",
        "    \"app_test\": \"application_test.csv\",\n",
        "    \"bureau\": \"bureau.csv\",\n",
        "    \"bureau_bal\": \"bureau_balance.csv\",\n",
        "    \"prev_app\": \"previous_application.csv\",\n",
        "    \"pos_cash\": \"POS_CASH_balance.csv\",\n",
