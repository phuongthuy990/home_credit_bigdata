        "# ── Khởi tạo Spark ─────────────────────────────────────────────\n",
        "spark = SparkSession.builder \\\n",
        "    .appName(\"HomeCreditDefaultRisk\") \\\n",
        "    .config(\"spark.sql.shuffle.partitions\", \"200\") \\\n",
        "    .config(\"spark.driver.memory\", \"4g\") \\\n",
        "    .getOrCreate()\n",
        "\n",
        "spark.sparkContext.setLogLevel(\"WARN\")\n",
        "\n",
        "# ── Đường dẫn dữ liệu ──────────────────────────────────────────\n",
